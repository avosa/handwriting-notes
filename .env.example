# This app has no backend and reads no secrets at build time.
#
# Each AI provider's API key is entered once inside the app (the key icon) and stored
# only in your browser's local database. Keys are never bundled, committed, or sent
# anywhere except their own vendor. There is nothing required to configure here.
#
# The only optional variables are the default model per provider, baked in at build
# time. Copy this file to .env.local and set any you want to override; the app ships
# with sensible defaults, so leaving these unset is fine.
VITE_ANTHROPIC_MODEL=claude-sonnet-5
VITE_OPENAI_MODEL=gpt-5.5
VITE_GEMINI_MODEL=gemini-flash-latest
VITE_DEEPSEEK_MODEL=deepseek-v4-flash
# Manus picks an agent profile rather than a model name: manus-1.6, manus-1.6-lite, or manus-1.6-max.
VITE_MANUS_PROFILE=manus-1.6
